{
  "dataset": "../data/water_potability.csv",
  "target": "Potability",
  "features": [
    "ph",
    "Hardness",
    "Solids",
    "Chloramines",
    "Sulfate",
    "Conductivity",
    "Organic_carbon",
    "Trihalomethanes",
    "Turbidity"
  ],
  "seeds": [
    42,
    123,
    2026
  ],
  "test_size": 0.2,
  "cv_folds": 5,
  "parameter_grid": {
    "C": [
      0.1,
      1,
      10
    ],
    "gamma": [
      "scale",
      "auto",
      0.01
    ],
    "kernel": "rbf"
  },
  "primary_metric": "f1",
  "output_directory": "outputs_svm_rbf"
}